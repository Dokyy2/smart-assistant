<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Waily Digital Assistant</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">

<style>
:root {
    --primary-color: #2563eb;
    --accent-color: #3b82f6;
    --bg-dark: #0f172a;
    --glass-bg: rgba(255, 255, 255, 0.92);
}

* { box-sizing: border-box; }

body {
    margin: 0;
    direction: rtl;
    font-family: 'Cairo', sans-serif;
    /* خلفية متحركة رقمية */
    background: linear-gradient(-45deg, #0f172a, #1e293b, #2563eb, #1e293b);
    background-size: 400% 400%;
    animation: gradientBG 15s ease infinite;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100vh;
    overflow: hidden;
}

@keyframes gradientBG {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

/* انيميشن ظهور الصفحة */
@keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
}

.chat-container {
    width: 100%;
    max-width: 450px;
    height: 90vh;
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border-radius: 30px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.3);
    animation: slideUp 0.8s ease-out;
}

/* Header مع تأثير نبض رقمي */
.header {
    padding: 20px;
    text-align: center;
    background: white;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    font-weight: 700;
    color: #1e293b;
    font-size: 1.1rem;
    position: relative;
}

.header::after {
    content: '';
    position: absolute;
    bottom: 0; left: 25%; width: 50%; height: 2px;
    background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
}

/* Chat Area */
.chat-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    background: rgba(248, 250, 252, 0.4);
}

/* انيميشن الرسائل */
@keyframes msgPop {
    from { opacity: 0; transform: scale(0.9) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}

.msg {
    max-width: 85%;
    padding: 14px 18px;
    border-radius: 20px;
    line-height: 1.6;
    font-size: 0.95rem;
    animation: msgPop 0.3s ease forwards;
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.bot-msg {
    background: white;
    color: #334155;
    align-self: flex-start;
    border-bottom-right-radius: 5px;
}

.user-msg {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: white;
    align-self: flex-end;
    border-bottom-left-radius: 5px;
}

.btn-link {
    display: block;
    margin-top: 12px;
    background: white;
    color: var(--primary-color);
    text-decoration: none;
    padding: 10px;
    border-radius: 12px;
    text-align: center;
    font-weight: 700;
    border: 2px solid var(--primary-color);
    transition: all 0.3s;
}

.btn-link:hover {
    background: var(--primary-color);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(37, 99, 235, 0.3);
}

/* Input Area */
.input-group {
    display: flex;
    padding: 20px;
    background: white;
    gap: 12px;
}

input {
    flex: 1;
    padding: 14px 20px;
    border-radius: 15px;
    border: 2px solid #f1f5f9;
    outline: none;
    font-family: inherit;
    transition: 0.3s;
}

input:focus {
    border-color: var(--primary-color);
    background: #f8fafc;
}

button {
    background: var(--primary-color);
    color: white;
    border: none;
    border-radius: 15px;
    padding: 0 25px;
    cursor: pointer;
    font-weight: 700;
    transition: 0.3s;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
}

button:hover {
    background: #1d4ed8;
    transform: scale(1.05);
}

/* Typing Animation */
.typing {
    display: flex;
    gap: 4px;
    padding: 15px 20px !important;
}

.dot {
    width: 6px; height: 6px; background: #94a3b8;
    border-radius: 50%; animation: blink 1.4s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

/* Scrollbar */
.chat-area::-webkit-scrollbar { width: 4px; }
.chat-area::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
</style>
</head>

<body>

<div class="chat-container">

    <div class="header">
        🤖 المساعد الرقمي - منطقة الوايلي
    </div>

    <div id="chatArea" class="chat-area">
        <div class="msg bot-msg">
            أهلاً بك 👋<br>
            معاك المساعد الذكي لمكاتب الصحة.. اكتب سؤالك وهرد عليك فوراً.
        </div>
    </div>

    <div class="input-group">
        <input id="userInput" placeholder="اسأل عن مواليد، وفيات، تطعيمات..." autocomplete="off">
        <button onclick="handleSend()">إرسال</button>
    </div>

</div>

<script>
// (نفس المنطق البرمجي الخاص بك مع تحسين بسيط في عرض الـ Typing)

const services = {
    "تسجيل شهادات الميلاد": {
        keywords: ["ميلاد","مولود","نونو","طفل","شهادة ميلاد","ميلتاد","بيبي","خلفنا","رزقنا"],
        link: "#"
    },
    "تسجيل شهادات الوفاة": {
        keywords: ["وفاة","مات","توفى","الميت","دفن","وفاه","تصريح","ترب"],
        link: "#"
    },
    "التطعيمات": {
        keywords: ["تطعيم","حقنة","مصل","تطيم","شلل","الصحة","حقنه"],
        link: "#"
    },
    "الجلدية": {
        keywords: ["جلدية","هرش","حساسية","جلد","كشف جلد","حبوب"],
        link: "#"
    },
    "الاستفسارات": {
        keywords: ["مواعيد","عنوان","فين","المكتب","شغالين","ساعة"],
        link: "#"
    }
};

function similarity(a, b) {
    let matches = 0;
    for (let i = 0; i < Math.min(a.length, b.length); i++) {
        if (a[i] === b[i]) matches++;
    }
    return matches / Math.max(a.length, b.length);
}

function detectService(text) {
    text = text.toLowerCase();
    let words = text.split(" ");
    for (let service in services) {
        for (let key of services[service].keywords) {
            if (text.includes(key)) return service;
        }
    }
    let bestMatch = null;
    let bestScore = 0;
    for (let service in services) {
        for (let key of services[service].keywords) {
            for (let word of words) {
                let score = similarity(word, key);
                if (score > bestScore) {
                    bestScore = score;
                    bestMatch = service;
                }
            }
        }
    }
    return bestScore > 0.5 ? bestMatch : null;
}

function getResponse(service) {
    if (service === "تسجيل شهادات الميلاد") {
        return `🎉 <b>ألف مبروك المولود الجديد!</b><br>تقدر تبدأ إجراءات تسجيل شهادة الميلاد من هنا: <br><a href="#" class="btn-link">عرض الأوراق المطلوبة</a>`;
    }
    if (service === "تسجيل شهادات الوفاة") {
        return `🙏 <b>البقاء لله..</b><br>ساعدنا الله على تسهيل إجراءاتكم. إليك دليل استخراج تصاريح الدفن والشهادة:<br><a href="#" class="btn-link">دليل الإجراءات</a>`;
    }
    return `✅ بخصوص <b>${service}</b>، تفضل بالاطلاع على التفاصيل من هنا:<br><a href="#" class="btn-link">فتح الرابط</a>`;
}

function handleSend() {
    let input = document.getElementById("userInput");
    let text = input.value.trim();
    if (!text) return;

    addMessage(text, "user");
    input.value = "";
    showTyping();

    setTimeout(() => {
        removeTyping();
        let service = detectService(text);
        if (service) {
            addMessage(getResponse(service), "bot");
        } else {
            addMessage("🤔 عذراً، لم أفهم طلبك جيداً.. هل تقصد الاستفسار عن المواليد أو التطعيمات؟", "bot");
        }
    }, 1500);
}

function addMessage(text, type) {
    let chat = document.getElementById("chatArea");
    let div = document.createElement("div");
    div.className = "msg " + (type === "user" ? "user-msg" : "bot-msg");
    div.innerHTML = text;
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
}

function showTyping() {
    let chat = document.getElementById("chatArea");
    let div = document.createElement("div");
    div.id = "typing";
    div.className = "msg bot-msg typing";
    div.innerHTML = '<div class="dot"></div><div class="dot"></div><div class="dot"></div>';
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
}

function removeTyping() {
    let t = document.getElementById("typing");
    if (t) t.remove();
}

document.getElementById("userInput").addEventListener("keydown", function(e){
    if (e.key === "Enter") {
        e.preventDefault();
        handleSend();
    }
});
</script>

</body>
</html>
